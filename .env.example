# =============================================================================
# ThreatNoir — environment variables
# =============================================================================
# Copy this file to .env (gitignored) and fill in your own values.
# For local development with Docker Supabase, see .env.local.example instead.

# -----------------------------------------------------------------------------
# REQUIRED — core platform
# -----------------------------------------------------------------------------

# Your Supabase project URL (https://<ref>.supabase.co)
SUPABASE_URL=
# Your Supabase project reference, e.g. abcdefghijklmnopqrst
# Used by certain admin/backfill scripts that call the Supabase Management API.
SUPABASE_PROJECT_REF=
# Anon key — safe to expose to the browser (RLS enforced)
SUPABASE_KEY=
# Service-role key — server-side only, bypasses RLS. NEVER ship to browser.
SUPABASE_SERVICE_KEY=
# Legacy alias for SUPABASE_SERVICE_KEY (keep set to same value if migrating from older clients)
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL used in canonical links, OG tags, RSS feeds, emails
NUXT_PUBLIC_SITE_URL=https://example.com

# Optional public social/profile URL(s) used in SEO + emails
NUXT_PUBLIC_SOCIAL_YOUTUBE_URL=

# Optional: client-side Supabase override (useful for Docker/self-hosted Supabase)
# If unset, the app uses SUPABASE_URL/SUPABASE_KEY.
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=

# Random secret protecting cron endpoints — generate with: openssl rand -base64 32
CRON_SECRET=

# Resend API key for transactional email (subscription confirmations, contact form, weekly digest)
# Get from https://resend.com → API Keys
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Email — senders, recipients, validation
# -----------------------------------------------------------------------------
#
# Production policy: missing recipient env vars cause requests to throw a 500
# error rather than silently send to admin@example.com. In development they
# log a warning and fall back to the placeholder.

# REQUIRED for sending email. Must use a Resend-verified sender on YOUR domain.
# Format: "Display Name <user@your-verified-domain.com>"
EMAIL_FROM=ThreatNoir <noreply@example.com>

# Optional sender overrides. Fall back to EMAIL_FROM if unset.
EMAIL_FROM_WELCOME=
EMAIL_FROM_NOTIFICATIONS=

# REQUIRED in production for each use case. Cascade to ADMIN_EMAIL in dev.
CONTACT_FORM_RECIPIENT=
LINKEDIN_DRAFT_RECIPIENT=
PODCAST_OWNER_EMAIL=
WEEKLY_DIGEST_PREVIEW_TO=
PREVIEW_EMAIL_FIXTURE=

# Generic fallback used by recipients above when their specific var is unset
# (dev only — production refuses to cascade silently).
ADMIN_EMAIL=

# DEPRECATED — use CONTACT_FORM_RECIPIENT. Kept here for backward compat.
# CONTACT_EMAIL=

# Public-facing contact email (client-side) for UI mailto links, etc.
NUXT_PUBLIC_CONTACT_EMAIL=contact@example.com

# -----------------------------------------------------------------------------
# AI pipeline (article summarize / classify / IOC extract / awareness lessons)
# -----------------------------------------------------------------------------

# Optional AI gateway (containerized/local deployments)
# If AI_GATEWAY_URL is empty, the server calls Anthropic directly.
AI_GATEWAY_URL=
# Required when AI_GATEWAY_URL is set. Generate with: openssl rand -hex 32
AI_GATEWAY_INTERNAL_TOKEN=
# Optional override for AI gateway calls (milliseconds)
AI_GATEWAY_TIMEOUT_MS=60000

# Anthropic API key — required for article summarization, awareness lessons, weekly roundups
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Global on/off switch — set to 'false' to disable all AI calls
AI_ENABLED=true

# Per-day call cap (article summarize cron stops when reached)
AI_DAILY_LIMIT=500

# Per-month budget cap in cents (article summarize stops when reached)
# Default 500 = $5/month. Bump to e.g. 40000 ($400) for production volume.
AI_MONTHLY_BUDGET_CENTS=500

# Relevance score (1-10) at or above which articles auto-approve
AI_AUTO_APPROVE_THRESHOLD=8
# Relevance score at or below which articles auto-reject
AI_AUTO_REJECT_THRESHOLD=3

# -----------------------------------------------------------------------------
# Public REST API (/api/v1/*) — optional API key auth
# -----------------------------------------------------------------------------

# Format: "key1:scope1,key2:scope2" — scope is currently "admin" or empty
THREATNOIR_API_KEYS=

# -----------------------------------------------------------------------------
# Image generation (weekly digest cover images) — optional
# -----------------------------------------------------------------------------

# OpenRouter API key for Gemini-based image generation (weekly cover art)
# Get from https://openrouter.ai
OPENROUTER_API_KEY=

# Cloudflare R2 (or any S3-compatible) for hosting generated images + audio
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=

# -----------------------------------------------------------------------------
# Social posting — all optional, omit any platform you don't use
# -----------------------------------------------------------------------------

# X (Twitter) OAuth credentials for auto-posting social drafts
X_BEARER_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Your X handle (without the @) — used in posted-tweet URL construction
X_USERNAME=

# Mastodon access token for cross-posting (default instance: infosec.exchange)
MASTODON_ACCESS_TOKEN=
MASTODON_INSTANCE_URL=https://infosec.exchange

# Discord bot for ops alerts (#alerts channel notifications)
DISCORD_BOT_TOKEN=
DISCORD_ALERTS_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Podcast pipeline (scripts/podcast/) — optional, only needed if running daily podcast
# -----------------------------------------------------------------------------

# ElevenLabs API key for podcast TTS
ELEVENLABS_API_KEY=
# Voice IDs from your ElevenLabs Voice Library (https://elevenlabs.io/app/voice-library)
ELEVENLABS_VOICE_ALEX=
ELEVENLABS_VOICE_MARCUS=

# Wondercraft API for podcast post-mastering (optional)
WONDERCRAFT_API_KEY=

# OpenAI API key (used by some podcast post-processing steps and embeddings)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# YouTube uploads (scripts/youtube/) — optional, only needed if publishing video briefings
# -----------------------------------------------------------------------------

# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Follow Google's OAuth flow once to obtain the refresh token (with youtube.upload scope).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Ops / admin tooling — optional
# -----------------------------------------------------------------------------

# Supabase Management API personal access token (for backfill/admin scripts)
# Get from https://supabase.com/dashboard/account/tokens
SUPABASE_PAT=

# Article ingestion freshness filter (in hours). Default 336 = 2 weeks
MAX_ARTICLE_AGE_HOURS=336
