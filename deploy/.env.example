# OSS platform (docker compose) — safe local defaults
#
# Copy to deploy/.env and adjust as needed:
#   cp deploy/.env.example deploy/.env

# Compose isolation
COMPOSE_PROJECT_NAME=threatnoir-platform

# Host ports (reserved band: 7000–7199)
APP_PORT=7000
SUPABASE_KONG_PORT=7100
SUPABASE_STUDIO_PORT=7101
SUPABASE_DB_PORT=7110
INBUCKET_PORT=7111

# -----------------------------------------------------------------------------
# Supabase (self-hosted)
# -----------------------------------------------------------------------------

# Postgres password for the self-hosted Supabase database
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# Database name (usually postgres)
POSTGRES_DB=postgres

# Legacy symmetric HS256 key (must be >= 32 chars)
# NOTE: This default matches the demo SUPABASE_KEY / SUPABASE_SERVICE_KEY below.
# If you change JWT_SECRET, regenerate both keys.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Legacy API keys (JWTs) signed with JWT_SECRET
# Use the well-known demo values by default. To generate your own, see:
# https://github.com/supabase/supabase/tree/master/docker (utils/generate-keys.sh)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Legacy fallback (prefer SUPABASE_SERVICE_KEY). Kept for compatibility with existing code.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase public URL (used by gotrue to build links). Defaults to kong host port.
SUPABASE_PUBLIC_URL=http://localhost:7100

# Auth URLs (used by gotrue)
SITE_URL=http://localhost:7000
API_EXTERNAL_URL=http://localhost:7100
ADDITIONAL_REDIRECT_URLS=http://localhost:7000/confirm
JWT_EXPIRY=3600
DISABLE_SIGNUP=false

# Email delivery (for local dev we use Inbucket)
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=inbucket
SMTP_PORT=2500
# Leave SMTP_USER/SMTP_PASS empty for local dev — Inbucket accepts unauthenticated
# SMTP and Go's stdlib refuses to send credentials over an unencrypted connection.
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Example Local
ENABLE_EMAIL_SIGNUP=true
# Autoconfirm new signups so the local-dev flow doesn't depend on clicking the
# Inbucket confirmation link. Set to false to exercise the full email flow.
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false

# PostgREST
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

# Studio meta crypto key
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
OPENAI_API_KEY=

# Optional: opaque API keys (leave empty; legacy JWT keys above are fine for Phase 1)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

# Kong dashboard basic auth (primarily for upstream supabase-kong config)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# Storage (file backend)
GLOBAL_S3_BUCKET=stub
STORAGE_TENANT_ID=stub
REGION=stub

# -----------------------------------------------------------------------------
# App env vars (match repo root .env.example)
# -----------------------------------------------------------------------------

CRON_SECRET=change-me-in-local-dev
RESEND_API_KEY=

X_BEARER_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

ANTHROPIC_API_KEY=
# Compose runs AI via the internal ai-gateway service. Set false to disable.
AI_ENABLED=true
AI_DAILY_LIMIT=500
AI_MONTHLY_BUDGET_CENTS=500
AI_AUTO_APPROVE_THRESHOLD=8
AI_AUTO_REJECT_THRESHOLD=3

# -----------------------------------------------------------------------------
# AI provider (ai-gateway)
# -----------------------------------------------------------------------------

# Choose which LLM powers the pipeline: `claude` (best quality; costs money), `openrouter` (multi-model; unified billing),
# `ollama` (local; lower quality), or `cli` (spawn a local CLI agent inside the gateway container).
# Setup walkthroughs: docs/AI-GATEWAY.md (Options: claude | openrouter | ollama | cli)
AI_PROVIDER=claude

# Ollama provider (operators run Ollama on the host; do NOT docker-compose it here)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# OpenRouter provider (OpenAI-compatible Chat Completions API)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Local CLI provider (Phase 4d)
# Runs a local CLI agent inside the ai-gateway container (e.g. claude-code).
# See docs/AI-GATEWAY.md for bind-mount vs image rebuild options.
AI_CLI_BIN=claude
# Important: prompts are sent via stdin; args only control output mode.
# Many CLI agents support JSON output via flags (example): "--print --output-format json".
AI_CLI_ARGS=--print
AI_CLI_TIMEOUT_MS=60000

# Internal-only token shared between app/cron and ai-gateway.
# Generate for deploy/.env (do NOT leave blank):
#   openssl rand -hex 32
# Route AI calls through the local gateway (default for docker compose).
# Leave empty to bypass the gateway and call Anthropic directly (Vercel / serverless mode).
AI_GATEWAY_URL=http://ai-gateway:8080

AI_GATEWAY_INTERNAL_TOKEN=

# Extra runtime tunables used by cron handlers
MAX_ARTICLE_AGE_HOURS=48

# -----------------------------------------------------------------------------
# Bootstrap (docker compose one-shot init)
# -----------------------------------------------------------------------------
# On first fresh `docker compose up`, the `bootstrap` service can:
#  1) seed an admin user (ADMIN_EMAIL + ADMIN_PASSWORD)
#  2) backfill recent articles (BACKFILL_HOURS)
#  3) optionally run AI summarization + awareness generation
#
# Cost note: BOOTSTRAP_RUN_AI=true triggers Anthropic spend on the first run.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpw1234
BACKFILL_HOURS=8
BOOTSTRAP_INGEST=true
BOOTSTRAP_RUN_AI=false

# Simple API key list for admin endpoints (format: key:role,key2:role2)
PLATFORM_API_KEYS=your-key-here:admin

# Public site URL used in UI links
NUXT_PUBLIC_SITE_URL=http://localhost:7000

# Optional: client-side supabase URL/key override for Nuxt runtimeConfig.public
NUXT_PUBLIC_SUPABASE_URL=http://localhost:7100
NUXT_PUBLIC_SUPABASE_KEY=${SUPABASE_KEY}
